{
  "name": "aetherai",
  "version": "0.1.12",
  "description": "AetherAI - Multi-provider AI aggregation client",
  "main": "electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "electron .",
    "dev": "concurrently -k \"npm run dev:renderer\" \"wait-on tcp:5173 && npm run dev:electron\"",
    "build": "vite build",
    "build:win": "vite build && electron-builder --win --x64",
    "build:ci": "vite build && electron-builder --win nsis portable --x64 --publish always",
    "start": "electron ."
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.11.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  }
}
